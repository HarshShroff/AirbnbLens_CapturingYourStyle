# AirbnbLens Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Backend Configuration
# ===========================================

# Server settings
HOST=0.0.0.0
PORT=8000

# ChromaDB path (relative to backend directory)
CHROMA_DB_PATH=./chroma_db

# CORS - comma-separated list of allowed origins
# For production, replace with your actual domain(s)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===========================================
# Hugging Face (Optional - for query expansion)
# ===========================================

# Get your token at https://huggingface.co/settings/tokens
# Leave empty or use placeholder to disable query augmentation
HF_API_TOKEN=hf_your_token_here

# ===========================================
# Frontend Configuration
# ===========================================

# API URL for frontend to connect to backend
NEXT_PUBLIC_API_URL=http://localhost:8000
